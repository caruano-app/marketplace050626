# Supabase
# Use a URL base do projeto, sem /rest/v1 no final.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_PUBLIC

# Somente servidor/Coolify. Nunca use NEXT_PUBLIC nesta chave.
# Necessaria para o Middleware e rotas admin lerem perfis mesmo com RLS restrito.
SUPABASE_SERVICE_ROLE_KEY=

# Debug temporario do middleware admin. Use "true" apenas durante teste e remova depois.
DEBUG_ADMIN_MIDDLEWARE=false

# Site/links publicos
NEXT_PUBLIC_SITE_URL=https://caruano.com

# Cloudflare Turnstile
# Chave publica do widget. A chave secreta fica somente no Supabase Auth.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Checkout/WhatsApp
# Apenas numeros com DDI/DDD. Exemplo: 5581999999999
NEXT_PUBLIC_MARKETPLACE_WHATSAPP=

# Usuario comprador padrao usado enquanto o checkout ainda nao exige login.
# Precisa ser um UUID existente na tabela usuarios para gravar transacoes_mestre.
NEXT_PUBLIC_CHECKOUT_COMPRADOR_ID=
